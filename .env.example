# ttrss の基本設定です。

# Web UI のホスト公開ポートです。
APP_PORT=8280

# 永続化データの保存先です。
HOST_DATA_DIR=./data
TTRSS_DB_DIR=./data/db
TTRSS_APP_DIR=./data/app
TTRSS_CONFIG_DIR=./data/config.d

# reverse proxy とつなぐための network / alias です。
PROXY_NETWORK_NAME=proxy-network
TTRSS_PROXY_ALIAS=ttrss

# コンテナ内タイムゾーンです。
TZ=Asia/Tokyo

# DB 接続情報です。
TTRSS_DB_USER=postgres
TTRSS_DB_NAME=postgres
TTRSS_DB_PASS=change-me

# ブラウザから見える正規 URL です。
# proxy 配下で使う場合は https://ttrss.example.local/tt-rss/ の形にします。
TTRSS_SELF_URL_PATH=http://localhost:8280/tt-rss/
